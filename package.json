{
  "name": "dsweb",
  "version": "0.1.0",
  "private": true,
  "description": "DS SmartLawn Service LLC — 自建系统（客户端网站 + 统一管理后台 + 银行支付网关）",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @dsweb/api prisma generate",
    "db:migrate": "pnpm --filter @dsweb/api prisma migrate dev",
    "db:seed": "pnpm --filter @dsweb/api db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
