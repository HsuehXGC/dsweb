# ============================================================
# DSweb 环境变量示例 —— 复制为 .env 并填入真实值（.env 不入库）
# ============================================================

# --- 运行环境 ---
NODE_ENV=development

# --- 数据库 (PostgreSQL 15+) ---
# 本地 Docker：postgresql://dsweb:dsweb@localhost:5432/dsweb
# 托管(Neon/Supabase/Render)：粘贴其连接串
DATABASE_URL=postgresql://dsweb:dsweb@localhost:5432/dsweb?schema=public

# --- Redis (会话 / 限流 / 队列) ---
REDIS_URL=redis://localhost:6379

# --- API 服务 ---
API_PORT=4000
API_BASE_URL=http://localhost:4000

# --- JWT (内部用户与终端客户使用不同 secret 与 audience) ---
JWT_INTERNAL_SECRET=change-me-internal-secret
JWT_CUSTOMER_SECRET=change-me-customer-secret
JWT_ACCESS_TTL=3600          # 1h
JWT_REFRESH_TTL=604800       # 7d

# --- 前端 ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
WEB_PORT=3000
ADMIN_PORT=3100

# --- 对象存储 (S3 / Cloudflare R2) ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=dsweb-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- 邮件 (SendGrid / Postmark / SES) ---
MAIL_PROVIDER=console        # console | sendgrid | postmark | ses
MAIL_FROM="DS SmartLawn <no-reply@dssmartlawn.com>"
SENDGRID_API_KEY=

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- 支付网关 ProCharge (Electronic Payments，NMI/AIM Direct Post) ---
# 默认 mock(模拟成功)；接真实网关时设为 procharge
PAYMENT_GATEWAY=mock
# Direct Post 端点(测试环境换成对应 URL)
PAYMENT_GATEWAY_URL=https://secure.procharge.com/api/transact.php
# Security Key：在 ProCharge Gateway → Settings → Security Keys 生成
PAYMENT_SECURITY_KEY=
PAYMENT_TRANSACTION_KEY=
PAYMENT_WEBHOOK_SECRET=
# 前端 Collect.js 令牌化(卡号不经服务器，PCI SAQ-A)
NEXT_PUBLIC_PAYMENT_COLLECTJS_URL=https://secure.procharge.com/token/Collect.js
NEXT_PUBLIC_PAYMENT_TOKENIZATION_KEY=

# --- 系统配置加密 (M9 settings 中敏感项 AES-256-GCM 加密密钥，≥16 字符) ---
SETTINGS_ENCRYPTION_KEY=change-me-settings-encryption-key

# --- 第三方 ---
GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
